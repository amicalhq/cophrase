{
  "name": "@workspace/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./queries/projects": "./src/queries/projects.ts",
    "./queries/content": "./src/queries/content.ts",
    "./queries/providers": "./src/queries/providers.ts",
    "./queries/models": "./src/queries/models.ts",
    "./queries/resources": "./src/queries/resources.ts",
    "./queries/agents": "./src/queries/agents.ts",
    "./queries/artifacts": "./src/queries/artifacts.ts",
    "./queries/agent-runs": "./src/queries/agent-runs.ts",
    "./queries/harness-messages": "./src/queries/harness-messages.ts",
    "./queries/content-types": "./src/queries/content-types.ts",
    "./crypto": "./src/crypto.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed.ts",
    "db:unseed": "tsx src/unseed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workspace/id": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.20.3",
    "typescript": "5.9.3"
  }
}
