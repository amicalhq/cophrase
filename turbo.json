{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "docker:build": {
      "cache": false
    },
    "docker:run": {
      "cache": false,
      "persistent": true
    },
    "docker:stop": {
      "cache": false
    },
    "docker:logs": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "inputs": ["$TURBO_DEFAULT$", "tests/**", "playwright.config.ts"],
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false
    }
  }
}
